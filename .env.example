# Email Provider: 'gmail', 'outlook', 'hotmail', 'office365', or 'yahoo'
# This automatically sets the correct IMAP host if EMAIL_HOST is not specified
EMAIL_PROVIDER=gmail

# Email Configuration (IMAP)
# For Gmail: imap.gmail.com
# For Outlook/Office365: outlook.office365.com
# For Yahoo: imap.mail.yahoo.com
EMAIL_HOST=
EMAIL_PORT=993
EMAIL_USERNAME=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_USE_SSL=true

# Examples:
# Gmail: EMAIL_PROVIDER=gmail, EMAIL_USERNAME=your-email@gmail.com
# Outlook: EMAIL_PROVIDER=outlook, EMAIL_USERNAME=your-email@outlook.com
# Office365: EMAIL_PROVIDER=office365, EMAIL_USERNAME=your-email@company.com

# Mailbox Configuration
EMAIL_INBOX_FOLDER=INBOX
EMAIL_PROCESSED_FOLDER=Processed

# Database Configuration (SQL Server)
DB_SERVER=localhost
DB_NAME=EmailAutomationDB
DB_USERNAME=db_user
DB_PASSWORD=db_password
DB_DRIVER=ODBC Driver 17 for SQL Server

# Application Configuration
DOWNLOAD_FOLDER=downloads
LOG_FOLDER=logs
CHECK_INTERVAL_MINUTES=5
# Set to 0 to disable date filtering (process emails from any date)
DATE_FILTER_DAYS=0

# Filter Configuration (comma-separated values)
# Leave empty to disable filtering (process all emails)
# ALLOWED_SENDERS=sender1@example.com,sender2@example.com
ALLOWED_SENDERS=
# SUBJECT_KEYWORDS=Report,Data,Excel,Sheet
SUBJECT_KEYWORDS=
FILE_EXTENSIONS=.xlsx,.xls,.csv
